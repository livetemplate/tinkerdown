# Test that help command and flags show usage information.

# help subcommand (outputs to stdout)
exec tinkerdown help
stdout 'tinkerdown - Interactive documentation made easy'
stdout 'Usage:'

# -h flag
exec tinkerdown -h
stdout 'Usage:'

# --help flag
exec tinkerdown --help
stdout 'Usage:'

# Unknown command exits with 1 and prints error to stderr
! exec tinkerdown nosuchcommand
stderr 'Unknown command: nosuchcommand'
